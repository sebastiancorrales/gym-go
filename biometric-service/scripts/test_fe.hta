<html>
<head>
<title>Test FeatureExtraction</title>
<hta:application id="oHTA" applicationname="TestFE" />
</head>
<body style="background:#1a1a2e;color:#0f0;font-family:Consolas;padding:20px">
<div id="out"></div>
<object id="DPCapture" classid="clsid:3FA859DA-300C-4247-BD33-6011198399C0" style="display:none"></object>

<script language="VBScript">
Dim gFE, gDone
gDone = False

Sub Log(msg)
    document.getElementById("out").innerHTML = document.getElementById("out").innerHTML & msg & "<br>"
End Sub

Sub Window_OnLoad()
    On Error Resume Next
    window.resizeTo 500, 400
    
    Log "=== Test FeatureExtraction ==="
    
    ' Test 1: CreateObject
    Log "Test CreateObject DPFPEngX.DPFPFeatureExtraction..."
    Set gFE = CreateObject("DPFPEngX.DPFPFeatureExtraction")
    If Err.Number <> 0 Then
        Log "<span style='color:red'>FAIL: " & Err.Description & " (0x" & Hex(Err.Number) & ")</span>"
        Err.Clear
    Else
        Log "<span style='color:lime'>OK! gFE created</span>"
    End If
    
    ' Test 2: CreateObject DPFPSample
    Log "Test CreateObject DPFPShrX.DPFPSample..."
    Dim s
    Set s = CreateObject("DPFPShrX.DPFPSample")
    If Err.Number <> 0 Then
        Log "<span style='color:red'>FAIL: " & Err.Description & " (0x" & Hex(Err.Number) & ")</span>"
        Err.Clear
    Else
        Log "<span style='color:lime'>OK! DPFPSample created</span>"
    End If
    
    Log ""
    Log "Starting capture... pon tu dedo"
    DPCapture.StartCapture
    If Err.Number <> 0 Then
        Log "<span style='color:red'>StartCapture FAIL: " & Err.Description & "</span>"
    Else
        Log "StartCapture OK"
    End If
    
    window.setTimeout "TimeoutHandler", 30000
End Sub

Sub TimeoutHandler()
    If gDone Then Exit Sub
    gDone = True
    Log "<span style='color:red'>TIMEOUT</span>"
    DPCapture.StopCapture
End Sub
</script>

<script language="VBScript" for="DPCapture" event="OnReaderConnect(SerNum)">
    Log "Reader: " & SerNum
</script>

<script language="VBScript" for="DPCapture" event="OnFingerTouch(SerNum)">
    Log "<span style='color:yellow'>FINGER TOUCH! " & SerNum & "</span>"
</script>

<script language="VBScript" for="DPCapture" event="OnComplete(SerNum, Sample)">
    On Error Resume Next
    If gDone Then Exit Sub
    gDone = True
    
    Log "<span style='color:lime'>*** CAPTURE COMPLETE ***</span>"
    
    ' Test: can we call Sample.Serialize?
    Dim raw
    raw = Sample.Serialize()
    If Err.Number <> 0 Then
        Log "<span style='color:red'>Sample.Serialize FAIL: " & Err.Description & "</span>"
        Err.Clear
    Else
        Log "Sample.Serialize OK: " & LenB(raw) & " bytes"
    End If
    
    ' Test: CreateFeatureSet with Sample directly
    Log "Calling CreateFeatureSet(Sample, 2)..."
    Dim fb
    fb = gFE.CreateFeatureSet(Sample, 2)
    If Err.Number <> 0 Then
        Log "<span style='color:red'>CreateFeatureSet(Sample) FAIL: " & Err.Description & " (0x" & Hex(Err.Number) & ")</span>"
        Err.Clear
        
        ' Test: serialize/deserialize workaround
        Log "Trying serialize/deserialize workaround..."
        Dim cleanSample
        Set cleanSample = CreateObject("DPFPShrX.DPFPSample")
        If Err.Number <> 0 Then
            Log "<span style='color:red'>CreateObject DPFPSample FAIL: " & Err.Description & "</span>"
            Err.Clear
        Else
            cleanSample.Deserialize raw
            If Err.Number <> 0 Then
                Log "<span style='color:red'>Deserialize FAIL: " & Err.Description & "</span>"
                Err.Clear
            Else
                Log "Deserialize OK, trying CreateFeatureSet(cleanSample)..."
                fb = gFE.CreateFeatureSet(cleanSample, 2)
                If Err.Number <> 0 Then
                    Log "<span style='color:red'>CreateFeatureSet(cleanSample) FAIL: " & Err.Description & " (0x" & Hex(Err.Number) & ")</span>"
                    Err.Clear
                Else
                    Log "<span style='color:lime'>CreateFeatureSet OK! feedback=" & fb & "</span>"
                    If fb = 0 Then
                        Dim fs
                        Set fs = gFE.FeatureSet
                        Dim d
                        d = fs.Serialize()
                        Log "<span style='color:lime'>FeatureSet OK: " & LenB(d) & " bytes!</span>"
                    End If
                End If
            End If
        End If
    Else
        Log "<span style='color:lime'>CreateFeatureSet(Sample) OK! feedback=" & fb & "</span>"
        If fb = 0 Then
            Dim fs2
            Set fs2 = gFE.FeatureSet
            Dim d2
            d2 = fs2.Serialize()
            Log "<span style='color:lime'>FeatureSet: " & LenB(d2) & " bytes!</span>"
        End If
    End If
    
    DPCapture.StopCapture
    Log "DONE."
</script>

</body>
</html>
