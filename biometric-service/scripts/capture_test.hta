<html>
<head>
<title>GymGo Capture Test</title>
<hta:application id="oHTA" applicationname="GymGoCaptureTest"
    border="thin" caption="yes" maximizebutton="no"
    scroll="no" showintaskbar="yes" singleinstance="no"
    sysmenu="yes" windowstate="normal" />
<style>
body { font-family: Segoe UI, sans-serif; margin: 15px; background: #1a1a2e; color: #e0e0e0; }
#status { font-size: 20px; color: #00ff88; margin: 10px 0; text-align: center; padding: 15px; background: #16213e; border-radius: 8px; }
#log { background: #0f3460; border: 1px solid #333; padding: 8px; height: 150px; overflow-y: auto; font-family: Consolas; font-size: 11px; white-space: pre-wrap; }
.ok { color: #00ff88; } .err { color: #ff4444; } .info { color: #00bfff; }
</style>
</head>
<body>
<div id="status">Iniciando...</div>
<div id="log"></div>

<object id="DPCapture" classid="clsid:3FA859DA-300C-4247-BD33-6011198399C0" style="display:none"></object>

<script language="VBScript">
Dim gFeatureExtract
Dim gDone
Dim gSample
gDone = False

Function BytesToBase64(bytes)
    Dim dom, node
    Set dom = CreateObject("MSXML2.DOMDocument")
    Set node = dom.createElement("b64")
    node.dataType = "bin.base64"
    node.nodeTypedValue = bytes
    BytesToBase64 = Replace(Replace(node.text, vbCr, ""), vbLf, "")
End Function

Sub WriteResultFile(jsonStr)
    Dim fso, tempDir, path
    Set fso = CreateObject("Scripting.FileSystemObject")
    tempDir = fso.GetSpecialFolder(2)
    path = tempDir & "\dp_bio_result.txt"
    Dim f
    Set f = fso.CreateTextFile(path, True)
    f.Write jsonStr
    f.Close
    AddLog "Result: " & path, "ok"
End Sub

Sub AddLog(msg, cls)
    On Error Resume Next
    document.getElementById("log").innerHTML = document.getElementById("log").innerHTML & "<span class='" & cls & "'>" & msg & "</span>" & vbCrLf
End Sub

Sub Window_OnLoad()
    On Error Resume Next
    window.resizeTo 450, 350
    
    Set gFeatureExtract = CreateObject("DPFPEngX.DPFPFeatureExtraction")
    If Err.Number <> 0 Then
        AddLog "Error FeatureExtraction: " & Err.Description, "err"
        Exit Sub
    End If
    AddLog "FeatureExtraction OK", "ok"
    
    DPCapture.StartCapture
    If Err.Number <> 0 Then
        AddLog "Error StartCapture: " & Err.Description, "err"
        Exit Sub
    End If
    AddLog "StartCapture OK", "ok"
    document.getElementById("status").innerText = "PON TU DEDO EN EL LECTOR (45s)"
    
    window.setTimeout "HandleTimeout", 45000
End Sub

Sub HandleTimeout()
    If gDone Then Exit Sub
    gDone = True
    document.getElementById("status").innerText = "TIMEOUT"
    DPCapture.StopCapture
    WriteResultFile "{""success"":false,""message"":""timeout""}"
    window.setTimeout "window.close", 2000
End Sub

Sub ProcessCapture()
    If gDone Then Exit Sub
    gDone = True
    On Error Resume Next
    
    Dim feedback
    feedback = gFeatureExtract.CreateFeatureSet(gSample, 2)
    AddLog "CreateFeatureSet feedback=" & feedback, "info"
    
    If feedback = 0 Then
        Dim fs
        Set fs = gFeatureExtract.FeatureSet
        Dim data
        data = fs.Serialize()
        Dim b64
        b64 = BytesToBase64(data)
        AddLog "FeatureSet: " & Len(b64) & " chars", "ok"
        
        document.getElementById("status").innerText = "CAPTURA EXITOSA!"
        WriteResultFile "{""success"":true,""message"":""ok"",""data"":{""template_data"":""" & b64 & """,""quality"":85}}"
    Else
        document.getElementById("status").innerText = "Mala calidad"
        WriteResultFile "{""success"":false,""message"":""bad quality: " & feedback & """}"
    End If
    
    DPCapture.StopCapture
    window.setTimeout "window.close", 1500
End Sub
</script>

<script language="VBScript" for="DPCapture" event="OnReaderConnect(SerNum)">
    AddLog "Reader conectado: " & SerNum, "ok"
</script>
<script language="VBScript" for="DPCapture" event="OnReaderDisconnect(SerNum)">
    AddLog "Reader desconectado: " & SerNum, "err"
</script>
<script language="VBScript" for="DPCapture" event="OnFingerTouch(SerNum)">
    AddLog "*** DEDO DETECTADO! ***", "ok"
    document.getElementById("status").innerText = "Capturando..."
</script>
<script language="VBScript" for="DPCapture" event="OnFingerGone(SerNum)">
    AddLog "Dedo retirado", "info"
</script>
<script language="VBScript" for="DPCapture" event="OnComplete(SerNum, Sample)">
    AddLog "CAPTURA COMPLETA!", "ok"
    Set gSample = Sample
    ProcessCapture
</script>
<script language="VBScript" for="DPCapture" event="OnSampleQuality(SerNum, Feedback)">
    If Feedback = 0 Then AddLog "Calidad: buena", "ok" Else AddLog "Calidad: " & Feedback, "err"
</script>

</body>
</html>
