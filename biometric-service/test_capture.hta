<html>
<head>
<title>Fingerprint Capture Test</title>
<hta:application id="oHTA" applicationname="FPCapture" border="dialog" borderstyle="normal"
    caption="yes" contextmenu="no" maximizebutton="no" minimizebutton="no"
    scroll="no" showintaskbar="yes" singleinstance="yes"
    sysmenu="yes" windowstate="normal" />
<style>
body { font-family: Consolas, monospace; font-size: 14px; margin: 20px; background: #1a1a2e; color: #eee; }
#status { color: #00ff88; font-size: 18px; margin: 10px 0; }
#log { background: #16213e; border: 1px solid #444; padding: 10px; height: 300px; overflow-y: auto; white-space: pre-wrap; }
.touch { color: #00ff88; font-weight: bold; }
.connect { color: #00bfff; }
.disconnect { color: #ffaa00; }
.complete { color: #00ff88; font-weight: bold; font-size: 16px; }
.error { color: #ff4444; }
</style>
</head>
<body>
<h2>Test Fingerprint Capture - HTA</h2>
<div id="status">Cargando...</div>
<div id="log"></div>

<object id="Capture" classid="clsid:3FA859DA-300C-4247-BD33-6011198399C0" style="display:none"></object>

<script language="VBScript">

Dim captureStarted

Sub AddLog(msg, cls)
    Dim logDiv
    Set logDiv = document.getElementById("log")
    logDiv.innerHTML = logDiv.innerHTML & "<span class='" & cls & "'>" & msg & "</span>" & vbCrLf
    logDiv.scrollTop = logDiv.scrollHeight
End Sub

Sub Window_OnLoad()
    On Error Resume Next
    document.getElementById("status").innerText = "Iniciando captura..."
    AddLog "DPFPCapture object creado via classid", ""
    
    Capture.StartCapture
    If Err.Number <> 0 Then
        AddLog "ERROR StartCapture: " & Err.Description, "error"
        document.getElementById("status").innerText = "Error al iniciar captura"
        Err.Clear
    Else
        AddLog "StartCapture OK", ""
        document.getElementById("status").innerText = "PON TU DEDO EN EL LECTOR!"
        captureStarted = True
    End If
End Sub

</script>

<script language="VBScript" for="Capture" event="OnReaderConnect(SerNum)">
    AddLog "READER_CONNECT: " & SerNum, "connect"
</script>

<script language="VBScript" for="Capture" event="OnReaderDisconnect(SerNum)">
    AddLog "READER_DISCONNECT: " & SerNum, "disconnect"
</script>

<script language="VBScript" for="Capture" event="OnFingerTouch(SerNum)">
    AddLog "*** FINGER TOUCH! *** " & SerNum, "touch"
    document.getElementById("status").innerText = "DEDO DETECTADO! Capturando..."
</script>

<script language="VBScript" for="Capture" event="OnFingerGone(SerNum)">
    AddLog "FINGER_GONE: " & SerNum, ""
</script>

<script language="VBScript" for="Capture" event="OnComplete(SerNum, Sample)">
    AddLog "*** CAPTURE COMPLETE! *** " & SerNum, "complete"
    document.getElementById("status").innerText = "CAPTURA EXITOSA!"
    
    On Error Resume Next
    Dim data
    data = Sample.Serialize()
    If Err.Number = 0 Then
        AddLog "Sample serializado: " & LenB(data) & " bytes", "complete"
    Else
        AddLog "Error serialize: " & Err.Description, "error"
        Err.Clear
    End If
</script>

<script language="VBScript" for="Capture" event="OnSampleQuality(SerNum, Feedback)">
    AddLog "SAMPLE_QUALITY: " & Feedback & " (serial: " & SerNum & ")", ""
</script>

</body>
</html>
